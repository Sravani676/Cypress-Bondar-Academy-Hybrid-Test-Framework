{
  "name": "cypress",
  "version": "1.0.0",
  "description": "Hybrid UI + API Test Framework using Cypress for automationexercise.com",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:open": "cypress open",
    "test:run": "cypress run",
    "test:ui": "cypress run --spec 'cypress/e2e/ui/**/*.cy.js'",
    "test:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js'",
    "test:smoke": "cypress run --env grepTags=smoke",
    "test:regression": "cypress run --env grepTags=regression",
    "test:headed": "cypress run --headed --no-exit",
    "test:report": "npx mochawesome-merge cypress/reports/mochawesome/*.json > cypress/reports/mochawesome.json && npx marge cypress/reports/mochawesome.json -f report -o cypress/reports",
    "test:run:report": "npm run cy:run && npm run cy:report",
    "lint": "eslint cypress/**/*.js"
  },
  "devDependencies": {
    "@bahmutov/cy-api": "^2.2.10",
    "@cypress/grep": "^4.1.1",
    "@faker-js/faker": "^8.4.0",
    "@types/cypress": "^0.1.6",
    "@types/mocha": "^10.0.10",
    "crypto-js": "^4.2.0",
    "cypress": "^15.12.0",
    "cypress-mochawesome-reporter": "^3.8.2",
    "cypress-real-events": "^1.13.0",
    "cypress-xpath": "^2.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-cypress": "^2.15.1",
    "marge": "^1.0.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "serialize-javascript": "^7.0.4",
    "typescript": "^6.0.2"
  },
  "author": "Sravani Bachuwar",
  "license": ""
}
