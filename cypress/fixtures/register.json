{
  "invalidRegistrationValues": {
    "blankPassword": {
      "expectedUIError": "password can't be blank",
      "expectedApiError": {
        "errorKey": "password",
        "errorValue": "can't be blank"
      }
    },
    "blankEmail": {
      "expectedUIError": "email can't be blank",
      "expectedApiError": {
        "errorKey": "email",
        "errorValue": "can't be blank"
      }
    },
    "blankUsername": {
      "expectedUIError": "username can't be blank",
      "expectedApiError": {
        "errorKey": "username",
        "errorValue": "can't be blank"
      }
    },
    "existingEmail": {
      "expectedUIError":"email has already been taken",
      "expectedApiError": {
        "errorKey": "email",
        "errorValue": "has already been taken"
      }
    },
    "existingUsername": {
      "expectedUIError":"username has already been taken",
      "expectedApiError": {
        "errorKey": "username",
        "errorValue": "has already been taken"
      }
    },
    "greaterThanMaxPasswordLength": {
      "expectedUIError":"password is too long (maximum is 20 characters)",
      "expectedApiError": {
        "errorKey": "password",
        "errorValue": "is too long (maximum is 20 characters)"
      }
    },
    "shorterThanMinPasswordLength": {
      "expectedUIError":"password is too short (minimum is 8 characters)",
      "expectedApiError": {
        "errorKey": "password",
        "errorValue": "is too short (minimum is 8 characters)"
      }
    },
    "invalidEmailFormat": {
      "expectedUIError":"email is invalid",
      "expectedApiError": {
        "errorKey": "email",
        "errorValue": "is invalid"
      }
    }
  }
}
